# Secrets — jamais commités
.env

# Config voix liée au compte ElevenLabs (perso) — un .example est fourni
references/profiles/*/voice-config.json

# Contenu de production (tes vidéos : audio, images, mp4, scripts, configs de projet)
projects/*
!projects/.gitkeep
!projects/_example/
!projects/_example/**

# Dépendances et build
node_modules/

# Logs et temporaires
*.log
**/_font.ttf
